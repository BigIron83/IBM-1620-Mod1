.venv/
__pycache__/
.pytest_cache/
.mypy_cache/
*.pyc
*.pyo
*.pyd

# Local app data
data/cache/*
!data/cache/.gitkeep
data/extracted/*
!data/extracted/.gitkeep
data/exports/*
!data/exports/.gitkeep
data/exports/*.csv

